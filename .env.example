# ============================================================
#  Configuración de sync-ml.js  (copia este archivo como .env)
# ============================================================

# --- Credenciales de tu app de Mercado Libre ---
# Las obtienes en https://developers.mercadolibre.cl  ->  "Crear aplicación"
ML_CLIENT_ID=tu_app_id
ML_CLIENT_SECRET=tu_client_secret

# Debe coincidir EXACTAMENTE con el "URI de redirect" de tu app de ML.
# Mercado Libre exige HTTPS. Usamos localhost (el navegador mostrará un error
# al redirigir, pero copiarás el code= de la barra de direcciones).
ML_REDIRECT_URI=https://localhost:3000/callback

# Dominio de autorización según tu país (Chile = .cl). Otros: .com.ar, .com.mx, etc.
ML_AUTH_DOMAIN=https://auth.mercadolibre.cl

# --- Comportamiento ---
# Cada cuántos minutos revisar ventas nuevas
POLL_MINUTES=5

# Cuántos días hacia atrás revisar como máximo (la sync es incremental sobre el último chequeo).
LOOKBACK_DAYS=7

# Usar el costo de envío REAL del vendedor (GET /shipments/{id}/costs).
# true  -> usa lo que ML cobró al vendedor por el envío (recomendado, exacto).
# false -> usa el "Costo Envío" configurado en cada producto.
USE_REAL_SHIPPING=true

# Comisiones de respaldo (SOLO se usan si una venta no trae el sale_fee real de ML).
# Ahora la comisión se toma del campo real sale_fee de cada venta; estos % son fallback.
COMMISSION_CLASSIC=0.135
COMMISSION_PREMIUM=0.165

# --- Firebase ---
# El script usa serviceAccountKey.json (descárgalo desde la consola de Firebase).
# No se necesita ninguna variable extra aquí para Firebase.

# ============================================================
#  Notificaciones por correo (NexSell) — proveedor Resend
# ============================================================
# El sistema de emails es OPCIONAL: si no defines RESEND_API_KEY, el sync
# funciona igual y simplemente NO envía correos (no-op silencioso).
#
# 1) Crea una cuenta gratis en https://resend.com
# 2) Ve a "API Keys" -> "Create API Key" y copia la clave (empieza con re_...).
# 3) Pégala aquí. Con el remitente de prueba onboarding@resend.dev puedes
#    enviar correos SOLO a la dirección con la que te registraste en Resend.
#    Para enviar a cualquier destinatario necesitas verificar tu propio dominio
#    en Resend y cambiar EMAIL_FROM a una dirección de ese dominio.
RESEND_API_KEY=re_TU_API_KEY

# A dónde llegan los avisos (ventas, stock bajo, reportes). Por defecto, la cuenta dueña.
REPORT_EMAIL=futuretech.cl.668@gmail.com

# Remitente. Para pruebas usa el de Resend; con dominio propio: "NexSell <avisos@tudominio.cl>".
EMAIL_FROM=NexSell <onboarding@resend.dev>

# Interruptor general de los correos. Ponlo en false para desactivarlos sin borrar la API key.
EMAIL_ENABLED=true

# Correo de BIENVENIDA al registrarse una cuenta nueva (true por defecto).
# OJO: con el remitente de prueba onboarding@resend.dev solo llega a TU propio
# correo de Resend. Para enviar bienvenidas a CUALQUIER usuario, verifica un
# dominio propio en Resend y cambia EMAIL_FROM a una dirección de ese dominio.
WELCOME_EMAIL_ENABLED=true

# ============================================================
#  Gmail SMTP — ALTERNATIVA a Resend (envía a CUALQUIER correo, gratis)
# ============================================================
# Si defines GMAIL_USER + GMAIL_APP_PASSWORD, los correos salen por tu Gmail
# (tiene PRIORIDAD sobre Resend). Permite enviar a cualquier destinatario sin
# verificar dominio. Requiere activar "Verificación en 2 pasos" en la cuenta y
# generar una "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
GMAIL_USER=tucuenta@gmail.com
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
EMAIL_FROM_NAME=NexSell

# Reportes POR USUARIO: cada cuenta (no dueña) recibe su propio resumen semanal
# (lunes) y mensual (día 1) con el progreso de su meta, a su propio correo. (true por defecto)
USER_REPORTS_ENABLED=true

# ============================================================
#  Backend en RENDER (render-backend/server.js)  —  API /api/* + cron
# ============================================================
# Estas variables se configuran en el panel de Render (Environment), NO en el repo.

# URL pública del backend en Render (a donde apunta API_BASE del index.html y
# el redirect_uri de OAuth ML). Ej: https://nexsell-backend.onrender.com
URL=https://nexsell-backend.onrender.com

# URL del FRONT en Vercel: a donde vuelve el usuario tras conectar Mercado Libre.
APP_URL=https://tu-app.vercel.app

# API de Mercado Libre (opcional; por defecto https://api.mercadolibre.com).
ML_API=https://api.mercadolibre.com

# Service account de Firebase como JSON en UNA sola línea (contenido de
# serviceAccountKey.json). Lo usan las funciones para escribir en Firestore por REST.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}

# Chat IA: clave de OpenRouter (la usa la función ai-proxy; nunca va en el HTML).
OPENROUTER_API_KEY=sk-or-...

# Correo del dueño (avisos/control).
OWNER_EMAIL=tucuenta@gmail.com

# Clave que el cron externo debe mandar en ?key=... para disparar /run-sync y /run-emails.
RUN_SECRET=inventa-una-clave-larga-y-secreta
